@model LoginViewModel
@{ Layout = null; ViewData["Title"] = "Admin Login"; }
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login — FileVault</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="~/css/admin.css" rel="stylesheet" />
</head>
<body class="adm-body">
    <div class="adm-login-page">
        <div class="adm-login-bg"></div>
        <div class="adm-login-card animate-slide-up">
            <div class="text-center mb-4">
                <div class="adm-login-icon"><i class="bi bi-shield-lock-fill"></i></div>
                <h2 class="mt-3 fw-800">Admin Panel</h2>
                <p class="adm-text-muted">Sign in with your administrator account</p>
            </div>
            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="alert alert-danger small" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>
                <div class="mb-3">
                    <label class="adm-label">Email</label>
                    <div class="input-group">
                        <span class="input-group-text adm-input-icon"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Email" class="form-control adm-input" placeholder="admin@filevault.local" autocomplete="email" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="adm-label">Password</label>
                    <div class="input-group">
                        <span class="input-group-text adm-input-icon"><i class="bi bi-lock"></i></span>
                        <input asp-for="Password" class="form-control adm-input" placeholder="••••••••" autocomplete="current-password" />
                    </div>
                </div>
                <div class="form-check mb-4">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label class="form-check-label adm-text-muted small" asp-for="RememberMe">Keep me signed in</label>
                </div>
                <button type="submit" class="btn adm-btn-primary w-100">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                </button>
            </form>
            <div class="text-center mt-4">
                <small class="adm-text-muted">FileVault Admin Panel · Only administrators can access this area</small>
            </div>
        </div>
    </div>
</body>
</html>
