@model UserDetailsViewModel
@{ ViewData["Title"] = "User Profile Detail"; }

<div class="adm-topbar animate-slide-up">
    <div class="d-flex align-items-center gap-3">
        <a href="/Users" class="adm-btn-icon"><i class="bi bi-arrow-left"></i></a>
        <h1 class="adm-page-title mb-0">User Profile</h1>
    </div>
    <div class="d-flex gap-2">
        <button type="button" class="btn adm-btn-ghost btn-sm px-3" onclick="openEditUserModal('@Model.Id')">
            <i class="bi bi-pencil-square me-2"></i>Edit Details
        </button>
        @if (Model.IsActive) {
            <form asp-action="Disable" asp-route-id="@Model.Id" method="post">
                <button type="submit" class="btn btn-warning btn-sm px-3" onclick="return confirm('Disable this user?')">
                    <i class="bi bi-slash-circle me-2"></i>Disable
                </button>
            </form>
        } else {
            <form asp-action="Enable" asp-route-id="@Model.Id" method="post">
                <button type="submit" class="btn btn-success btn-sm px-3">
                    <i class="bi bi-check-circle me-2"></i>Enable
                </button>
            </form>
        }
    </div>
</div>

<div class="row g-4">
    <!-- Main Info Col -->
    <div class="col-lg-8 animate-on-scroll">
        <div class="adm-card p-4">
            <div class="d-flex align-items-center gap-4 mb-5 pb-4 border-bottom border-light border-opacity-10">
                <div class="adm-avatar-lg" style="width: 100px; height: 100px; font-size: 3rem; background: var(--grad-primary); border-radius: 24px; display: flex; align-items: center; justify-content: center; box-shadow: var(--grad-glow);">
                    <i class="bi bi-person-fill text-cream"></i>
                </div>
                <div class="flex-grow-1">
                    <h2 class="fw-900 mb-1">@Model.FullName</h2>
                    <div class="adm-text-muted fs-5 mb-2">@Model.Email</div>
                    <div class="d-flex gap-2 flex-wrap">
                        @foreach(var role in Model.Roles) {
                            <span class="badge adm-badge-lg">@role</span>
                        }
                        @if (Model.EmailConfirmed) {
                            <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2 rounded-pill"><i class="bi bi-patch-check-fill me-2"></i>Verified</span>
                        }
                    </div>
                </div>
            </div>

            <h6 class="adm-label mb-4 opacity-100">System Credentials & Attributes</h6>
            <div class="row g-4 mb-5">
                <div class="col-md-6">
                    <div class="p-3 rounded-4" style="background: rgba(255,255,255,0.02); border: 1px solid var(--adm-card-border);">
                        <label class="adm-label mb-1">User Identifier</label>
                        <div class="fw-700 font-monospace small">@Model.Id</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-3 rounded-4" style="background: rgba(255,255,255,0.02); border: 1px solid var(--adm-card-border);">
                        <label class="adm-label mb-1">Account Status</label>
                        <div class="fw-700">
                             @if (Model.IsActive) { <span class="text-success"><i class="bi bi-circle-fill me-2 small"></i>Active Operational</span> }
                             else { <span class="text-danger"><i class="bi bi-circle-fill me-2 small"></i>Service Suspended</span> }
                        </div>
                    </div>
                </div>
                <div class="col-12">
                    <div class="p-3 rounded-4" style="background: rgba(255,255,255,0.02); border: 1px solid var(--adm-card-border);">
                        <label class="adm-label mb-1">Password Authentication</label>
                        <div class="fw-700 font-monospace text-break opacity-75 small">
                            <span class="text-muted small me-2">Algorithm: BCrypt | Hash:</span> @Model.PasswordHash
                        </div>
                    </div>
                </div>
            </div>

            <h6 class="adm-label mb-4 opacity-100">Storage & Asset Utilization</h6>
            <div class="row g-3 mb-2">
                <div class="col-sm-4">
                    <div class="text-center p-3 rounded-4 border border-light border-opacity-10" style="background: rgba(255,255,255,0.01);">
                        <div class="display-6 fw-800">@Model.FileCount</div>
                        <div class="adm-text-dim small fw-700 text-uppercase">Files Managed</div>
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="text-center p-3 rounded-4 border border-light border-opacity-10" style="background: rgba(255,255,255,0.01);">
                        <div class="display-6 fw-800">@Model.FolderCount</div>
                        <div class="adm-text-dim small fw-700 text-uppercase">Folders created</div>
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="text-center p-3 rounded-4 border border-light border-opacity-10" style="background: rgba(255,255,255,0.01);">
                        <div class="display-6 fw-800">@Model.StorageFormatted</div>
                        <div class="adm-text-dim small fw-700 text-uppercase">Total Consumed</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sidebar Info Col -->
    <div class="col-lg-4 animate-on-scroll">
        <div class="adm-card p-4 mb-4">
            <h6 class="adm-card-title mb-4 pb-2 border-bottom border-light border-opacity-10">
                <i class="bi bi-clock-history me-2 adm-text-accent"></i>Lifecycle
            </h6>
            <div class="d-flex flex-column gap-3">
                <div class="p-3 rounded-4" style="background: rgba(75, 38, 47, 0.1); border: 1px solid var(--adm-accent);">
                    <label class="adm-label mb-1 opacity-75">Registration Date</label>
                    <div class="fw-700 fs-5">@Model.CreatedAt.ToString("MMMM dd, yyyy")</div>
                    <div class="adm-text-muted small">@Model.CreatedAt.ToString("HH:mm:ss") (UTC)</div>
                </div>
                <div class="p-3 rounded-4" style="background: rgba(255, 255, 255, 0.02); border: 1px solid var(--adm-card-border);">
                    <label class="adm-label mb-1 opacity-75">Email Verification</label>
                    <div class="fw-700">
                        @if (Model.EmailConfirmed) { <span class="text-success"><i class="bi bi-check2-all me-2"></i>Completed</span> }
                        else { <span class="text-warning"><i class="bi bi-exclamation-triangle me-2"></i>Pending Verification</span> }
                    </div>
                </div>
            </div>
        </div>

        <div class="adm-card p-4">
            <h6 class="adm-card-title mb-4 pb-2 border-bottom border-light border-opacity-10">
                <i class="bi bi-lightning-charge-fill me-2 text-warning"></i>Recent Sessions
            </h6>
            <div class="adm-activity-feed" style="max-height: 400px; overflow-y: auto; padding-right: 10px;">
                @foreach (var log in Model.RecentActivity)
                {
                    <div class="adm-activity-item mb-3 pb-3 border-bottom border-light border-opacity-5">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="badge adm-badge small">@log.Action</span>
                            <small class="adm-text-dim">@log.CreatedAt.ToString("MMM dd")</small>
                        </div>
                        <div class="adm-text-muted x-small">
                            <i class="bi bi-globe me-1"></i> @(log.IpAddress ?? "Unknown IP")
                        </div>
                    </div>
                }
                @if (!Model.RecentActivity.Any()) {
                    <div class="text-center py-4 adm-text-dim">No recent activity detected.</div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Reusing Edit Modal Logic from Index but for single user -->
<partial name="_EditUserModalPartial" model="Model" />

@section Scripts {
    <script>
        function openEditUserModal(id) {
             new bootstrap.Modal(document.getElementById('editUserModal')).show();
        }
    </script>
}
