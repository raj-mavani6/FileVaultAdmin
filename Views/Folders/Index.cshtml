@model FolderListViewModel
@{ ViewData["Title"] = "Folder Browser"; }

<!-- Toolbar -->
<div class="adm-toolbar d-flex justify-content-between align-items-center mb-4 gap-3">
    <div class="adm-toolbar-left">
        <form method="get" class="d-flex gap-2 flex-wrap">
            <input type="text" name="search" value="@Model.SearchTerm" class="form-control adm-input" style="width: 250px;" placeholder="Search folders..." />
            <input type="text" name="owner" value="@Model.OwnerFilter" class="form-control adm-input" style="width: 200px;" placeholder="Owner user ID..." />
            <button type="submit" class="btn adm-btn-primary"><i class="bi bi-search me-1"></i>Filter</button>
            @if (!string.IsNullOrEmpty(Model.SearchTerm) || !string.IsNullOrEmpty(Model.OwnerFilter))
            { <a href="/Folders" class="btn adm-btn-ghost">Clear</a> }
        </form>
    </div>
    <div class="adm-toolbar-right d-flex align-items-center gap-3">
        <span class="badge adm-badge-lg">@Model.TotalFolders folders</span>
        <button type="button" class="btn adm-btn-primary" data-bs-toggle="modal" data-bs-target="#addFolderModal">
            <i class="bi bi-plus-lg me-1"></i>New Folder
        </button>
    </div>
</div>

<!-- Add Folder Modal -->
<div class="modal fade" id="addFolderModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content adm-toast">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-700">Create System Folder</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Create" method="post">
                <div class="modal-body">
                    <div class="mb-4">
                        <label class="adm-label">Target Owner</label>
                        <select name="ownerId" class="form-select adm-input" required>
                            <option value="">-- Select Owner --</option>
                            @foreach (var u in (List<FileVaultAdmin.Models.Domain.AppUser>)ViewBag.AllUsers)
                            {
                                <option value="@u.Id">@u.FullName (@u.Email)</option>
                            }
                        </select>
                        <small class="text-muted small">Choose the user who will own this system folder.</small>
                    </div>
                    <div class="mb-3">
                        <label class="adm-label">Folder Name</label>
                        <input type="text" name="name" class="form-control adm-input" placeholder="e.g. Project Assets" required />
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn adm-btn-ghost" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn adm-btn-primary">Create Folder</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="adm-card">
    <div class="table-responsive">
        <table class="table adm-table mb-0">
            <thead><tr><th>Folder</th><th>Owner</th><th>Files</th><th>Status</th><th>Created</th><th></th></tr></thead>
            <tbody>
            @foreach (var f in Model.Folders)
            {
                <tr class="animate-fade-in">
                    <td>
                        <div class="d-flex align-items-center">
                            <i class="bi bi-folder-fill me-2 adm-text-accent" style="font-size: 1.2rem;"></i>
                            <div>
                                <div class="fw-600">@f.Name</div>
                                <small class="adm-text-dim font-monospace">@f.Id[..Math.Min(10, f.Id.Length)]…</small>
                            </div>
                        </div>
                    </td>
                    <td class="adm-text-muted">@(f.OwnerEmail ?? f.OwnerUserId[..Math.Min(8, f.OwnerUserId.Length)])</td>
                    <td>
                        <span class="badge adm-badge">@f.FileCount files</span>
                    </td>
                    <td>
                        @if (f.IsDeleted) { <span class="badge bg-danger bg-opacity-25 text-danger">Trashed</span> }
                        else { <span class="badge bg-success bg-opacity-25 text-success">Active</span> }
                    </td>
                    <td class="adm-text-muted">@f.CreatedAt.ToString("MMM dd, yyyy")</td>
                    <td class="text-end">
                        <div class="d-flex gap-1 justify-content-end">
                            <a href="/Files?folderId=@f.Id" class="btn btn-sm adm-btn-icon text-info" title="View Files">
                                <i class="bi bi-eye"></i>
                            </a>
                            <form asp-action="Delete" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@f.Id" />
                                <button type="submit" class="btn btn-sm adm-btn-icon text-danger" title="Delete Permanently" onclick="return confirm('Permanently delete this folder and ALL files inside? This cannot be undone.')">
                                    <i class="bi bi-trash-fill"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Folders.Any())
            {
                <tr><td colspan="6" class="text-center py-5 adm-text-dim"><i class="bi bi-folder-x display-4 d-block mb-3 opacity-25"></i>No folders found</td></tr>
            }
            </tbody>
        </table>
    </div>
</div>

<!-- Pagination -->
@if (Model.TotalPages > 1)
{
    <nav class="mt-4 d-flex justify-content-center">
        <ul class="pagination">
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" href="/Folders?page=@i&search=@Model.SearchTerm&owner=@Model.OwnerFilter"
                       style="background: @(i == Model.Page ? "var(--adm-accent)" : "var(--adm-hover)"); border-color: var(--adm-card-border); color: var(--adm-text);">@i</a>
                </li>
            }
        </ul>
    </nav>
}
