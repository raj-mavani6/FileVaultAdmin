@using System.Security.Claims
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "Admin") — FileVault Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="~/css/admin.css?v=@DateTime.UtcNow.Ticks" rel="stylesheet" />
</head>
<body class="adm-body">
    <div class="adm-wrapper">
        <!-- Sidebar -->
        <aside class="adm-sidebar" id="sidebar">
            <div class="adm-sidebar-brand">
                <a href="/" class="adm-brand-link">
                    <div class="adm-brand-icon"><i class="bi bi-shield-lock-fill"></i></div>
                    <div>
                        <div class="adm-brand-name">FileVault</div>
                        <div class="adm-brand-sub">Admin Panel</div>
                    </div>
                </a>
            </div>

            <div class="adm-sidebar-section">
                <div class="adm-sidebar-label">Overview</div>
                <a href="/" class="adm-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                    <i class="bi bi-grid-1x2-fill"></i><span>Dashboard</span>
                </a>
            </div>

            <div class="adm-sidebar-section">
                <div class="adm-sidebar-label">Management</div>
                <a href="/Users" class="adm-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")">
                    <i class="bi bi-people-fill"></i><span>Users</span>
                    <span class="adm-nav-badge" id="userCountBadge"></span>
                </a>
                <a href="/Files" class="adm-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Files" ? "active" : "")">
                    <i class="bi bi-folder-fill"></i><span>Files</span>
                </a>
                <a href="/Shares" class="adm-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Shares" ? "active" : "")">
                    <i class="bi bi-link-45deg"></i><span>Share Links</span>
                </a>
                <a href="/Folders" class="adm-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Folders" ? "active" : "")">
                    <i class="bi bi-folder2-open"></i><span>Folders</span>
                </a>
                <a href="/Trash" class="adm-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Trash" ? "active" : "")">
                    <i class="bi bi-trash3"></i><span>Trash</span>
                </a>
            </div>

            <div class="adm-sidebar-section">
                <div class="adm-sidebar-label">Insights</div>
                <a href="/Analytics" class="adm-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Analytics" ? "active" : "")">
                    <i class="bi bi-graph-up-arrow"></i><span>Analytics</span>
                </a>
            </div>

            <div class="adm-sidebar-footer">
                <div class="adm-user-card">
                    <div class="adm-user-avatar">
                        <i class="bi bi-person-fill"></i>
                    </div>
                    <div class="adm-user-info">
                        <div class="adm-user-name">@User.FindFirstValue(ClaimTypes.Name)</div>
                        <div class="adm-user-email">@User.FindFirstValue(ClaimTypes.Email)</div>
                    </div>
                    <div class="ms-auto opacity-50">
                        <i class="bi bi-chevron-right small"></i>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main -->
        <div class="adm-main">
            <!-- Topbar -->
            <header class="adm-topbar">
                <button class="btn adm-btn-icon d-lg-none" id="sidebarToggle" onclick="document.getElementById('sidebar').classList.toggle('show')">
                    <i class="bi bi-list"></i>
                </button>
                <div class="adm-topbar-title">
                    <h1 class="adm-page-title">@(ViewData["Title"] ?? "Dashboard")</h1>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <button id="themeToggle" class="btn adm-btn-icon" onclick="toggleTheme()" title="Toggle theme">
                        <i class="bi bi-moon-stars-fill"></i>
                    </button>
                    <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn adm-btn-icon text-danger" title="Logout">
                            <i class="bi bi-box-arrow-right"></i>
                        </button>
                    </form>
                </div>
            </header>

            <!-- Content -->
            <div class="adm-content">
                <div id="toastContainer" class="toast-container position-fixed top-0 end-0 p-3" style="z-index:1100;"></div>
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/admin.js"></script>

    @if (TempData["Success"] != null)
    {
        <script>document.addEventListener('DOMContentLoaded', () => showToast('@TempData["Success"]', 'success'));</script>
    }
    @if (TempData["Error"] != null)
    {
        <script>document.addEventListener('DOMContentLoaded', () => showToast('@TempData["Error"]', 'danger'));</script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
