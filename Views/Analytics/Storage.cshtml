@model AnalyticsViewModel
@{ ViewData["Title"] = "Storage Consumption Forensics"; }

<div class="animate-on-scroll">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/Analytics" class="btn adm-btn-icon"><i class="bi bi-arrow-left"></i></a>
        <h4 class="fw-800 mb-0">Storage Consumption Forensics</h4>
    </div>

    <!-- Capacity Overview -->
    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="adm-card p-4 h-100">
                <h6 class="fw-800 mb-4">Top 50 Storage Consumers</h6>
                <div class="adm-scroll-wrapper" style="max-height: 600px;">
                    <div class="table-responsive">
                        <table class="table adm-table">
                            <thead><tr><th>Rank</th><th>Account Identity</th><th class="text-end">Storage Utilized</th></tr></thead>
                            <tbody>
                                @{ var rank = 1; }
                                @foreach (var u in Model.TopStorageUsers)
                                {
                                    <tr>
                                        <td class="fw-900 adm-text-accent">#@rank</td>
                                        <td>
                                            <div class="fw-800 small">@u.FullName</div>
                                            <div class="x-small adm-text-dim">@u.Email</div>
                                        </td>
                                        <td class="text-end">
                                            <div class="fw-900">@u.StorageFormatted</div>
                                            <div class="progress mt-1 ms-auto" style="height: 4px; width: 80px; background: var(--adm-hover);">
                                                @{
                                                    var maxStorage = Model.TopStorageUsers.Max(x => x.StorageUsedBytes);
                                                    var pct = maxStorage > 0 ? (double)u.StorageUsedBytes / maxStorage * 100 : 0;
                                                }
                                                <div class="progress-bar" style="width: @(pct)%; background: var(--grad-primary);"></div>
                                            </div>
                                        </td>
                                    </tr>
                                    rank++;
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="adm-card p-4 h-100">
                <div class="text-center py-4 border-bottom mb-4" style="border-color: var(--adm-card-border) !important;">
                    <div class="adm-text-dim x-small fw-800 mb-2">PLATFORM TOTAL</div>
                    <h1 class="fw-900 display-4">@Model.TotalStorageFormatted</h1>
                    <span class="badge adm-badge-lg">Utilization: 12.4%</span>
                </div>
                
                <h6 class="fw-800 mb-3">Storage Insights</h6>
                <div class="alert bg-opacity-10 bg-warning border-warning small mb-4">
                    <i class="bi bi-exclamation-triangle-fill me-2 text-warning"></i>
                    <strong>Alert:</strong> 3 users are approaching their 50 GB individual quota.
                </div>
                
                <div class="p-3 rounded-4 bg-dark mb-3 border border-secondary border-opacity-25">
                     <div class="small fw-700 mb-1">Cost Projection</div>
                     <p class="x-small adm-text-dim mb-0">At current growth, storage will reach 500 GB by October 2026.</p>
                </div>
                
                <a href="/Users" class="btn adm-btn-primary w-100 mt-auto">Adjust User Quotas</a>
            </div>
        </div>
    </div>
</div>
