@model ShareRowViewModel
@{ ViewData["Title"] = "Share Details"; }

<div class="adm-topbar animate-slide-up">
    <div class="d-flex align-items-center gap-3">
        <a href="/Shares" class="adm-btn-icon"><i class="bi bi-arrow-left"></i></a>
        <h1 class="adm-page-title mb-0">Share Details</h1>
    </div>
    <div class="d-flex gap-2">
        <form asp-action="ToggleStatus" asp-route-id="@Model.Id" method="post">
            <button type="submit" class="btn @(Model.IsRevoked ? "btn-success" : "btn-warning") btn-sm px-3">
                <i class="bi @(Model.IsRevoked ? "bi-check-circle" : "bi-slash-circle") me-2"></i>
                @(Model.IsRevoked ? "Restore" : "Revoke")
            </button>
        </form>
        <button class="btn btn-danger btn-sm px-3" data-bs-toggle="modal" data-bs-target="#deleteModal">
            <i class="bi bi-trash3 me-2"></i>Delete
        </button>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8 animate-on-scroll">
        <div class="adm-card p-4">
            <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-light border-opacity-10">
                <h6 class="adm-card-title mb-0"><i class="bi bi-info-circle-fill me-2 adm-text-accent"></i>Link Information</h6>
                <span class="badge adm-badge-lg">Permalink</span>
            </div>
            
            <div class="p-4 rounded-4 mb-4" style="background: rgba(255,255,255,0.02); border: 1px solid var(--adm-card-border);">
                <label class="adm-label mb-2">Public Access URL</label>
                <div class="input-group">
                    <span class="input-group-text adm-input bg-transparent border-end-0 px-3"><i class="bi bi-link-45deg"></i></span>
                    <input type="text" class="form-control adm-input border-start-0 font-monospace small" value="@ViewData["ShareLink"]" readonly id="shareUrl">
                    <button class="btn adm-btn-primary px-4" onclick="copyUrl()" id="copyBtn">
                        <i class="bi bi-clipboard me-2"></i>Copy
                    </button>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <div class="p-3 rounded-4 h-100" style="background: rgba(255,255,255,0.01); border: 1px solid var(--adm-card-border);">
                        <div class="adm-text-dim small fw-800 text-uppercase letter-spacing-1 mb-2">Secure Token</div>
                        <div class="fw-700 font-monospace text-break">@Model.Token</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-3 rounded-4 h-100" style="background: rgba(255,255,255,0.01); border: 1px solid var(--adm-card-border);">
                        <div class="adm-text-dim small fw-800 text-uppercase letter-spacing-1 mb-2">Associated File</div>
                        <div class="fw-700 d-flex align-items-center gap-2">
                            <i class="bi bi-file-earmark-text-fill fs-5 adm-text-accent"></i>
                            <span class="text-truncate">@Model.FileName</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-3 rounded-4 h-100" style="background: rgba(255,255,255,0.01); border: 1px solid var(--adm-card-border);">
                        <div class="adm-text-dim small fw-800 text-uppercase letter-spacing-1 mb-2">Owner Contact</div>
                        <div class="fw-700 d-flex align-items-center gap-2">
                            <i class="bi bi-person-badge-fill fs-5 opacity-50"></i>
                            <span class="text-truncate">@Model.OwnerEmail</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-3 rounded-4 h-100" style="background: rgba(255,255,255,0.01); border: 1px solid var(--adm-card-border);">
                        <div class="adm-text-dim small fw-800 text-uppercase letter-spacing-1 mb-2">Permissions Policy</div>
                        <div class="fw-700 d-flex align-items-center gap-2">
                             @if (Model.AllowDownload) { 
                                 <i class="bi bi-cloud-arrow-down-fill fs-5 text-success"></i>
                                 <span class="text-success">Unrestricted Download</span> 
                             } else { 
                                 <i class="bi bi-eye-fill fs-5 text-warning"></i>
                                 <span class="text-warning">View Only Protection</span> 
                             }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4 animate-on-scroll">
        <div class="adm-card p-4 h-100">
            <h6 class="adm-card-title mb-4 pb-2 border-bottom border-light border-opacity-10">
                <i class="bi bi-activity me-2 adm-text-accent"></i>Lifecycle & Analytics
            </h6>
            
            <div class="p-4 rounded-4 text-center mb-4" style="background: var(--grad-primary); box-shadow: var(--grad-glow);">
                <div class="display-5 fw-900 mb-1">@Model.AccessCount</div>
                <div class="adm-text-muted small fw-800 text-uppercase opacity-75">Total View Sessions</div>
            </div>

            <div class="d-flex flex-column gap-3">
                <div class="d-flex justify-content-between align-items-center p-3 rounded-3" style="background: rgba(255,255,255,0.02);">
                    <span class="adm-text-dim small fw-700">Generation Date</span>
                    <span class="fw-600">@Model.CreatedAt.ToString("MMM dd, yyyy")</span>
                </div>
                <div class="d-flex justify-content-between align-items-center p-3 rounded-3" style="background: rgba(255,255,255,0.02);">
                    <span class="adm-text-dim small fw-700">Expiration Threshold</span>
                    <span class="fw-600 @(Model.ExpiresAt.HasValue && Model.ExpiresAt < DateTime.UtcNow ? "text-danger" : "")">
                        @(Model.ExpiresAt?.ToString("MMM dd, yyyy") ?? "Infinite")
                    </span>
                </div>
                <div class="d-flex justify-content-between align-items-center p-3 rounded-3" style="background: rgba(238, 211, 186, 0.05);">
                    <span class="adm-text-dim small fw-700">Operational Status</span>
                    <span>
                        @if (Model.IsRevoked) { <span class="badge bg-danger bg-opacity-25 text-danger fw-800 px-3 py-2 rounded-pill">Administrative Revoke</span> }
                        else if (Model.ExpiresAt.HasValue && Model.ExpiresAt < DateTime.UtcNow) { <span class="badge bg-warning bg-opacity-25 text-warning fw-800 px-3 py-2 rounded-pill">Expired / Inactive</span> }
                        else { <span class="badge bg-success bg-opacity-25 text-success fw-800 px-3 py-2 rounded-pill">Active Live Link</span> }
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content adm-card border-0">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-800">Delete Permalink?</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pb-0">
                <p class="adm-text-muted">This action will permanently invalidate this share token. Users with the link will no longer be able to access the file.</p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-light btn-sm px-4" data-bs-dismiss="modal">Cancel</button>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                    <button type="submit" class="btn btn-danger btn-sm px-4">Confirm Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function copyUrl() {
        const input = document.getElementById('shareUrl');
        const btn = document.getElementById('copyBtn');
        const originalText = btn.innerHTML;
        
        input.select();
        document.execCommand('copy');
        
        btn.innerHTML = '<i class="bi bi-check2 me-2"></i>Copied!';
        btn.classList.replace('adm-btn-primary', 'btn-success');
        
        setTimeout(() => {
            btn.innerHTML = originalText;
            btn.classList.replace('btn-success', 'adm-btn-primary');
        }, 2000);
    }
</script>
}
