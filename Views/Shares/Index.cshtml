@model ShareListViewModel
@{ ViewData["Title"] = "Share Links"; }

<!-- Toolbar -->
<div class="adm-toolbar d-flex justify-content-between align-items-center mb-4 gap-3">
    <div class="adm-toolbar-left">
        <form method="get" class="d-flex gap-2 flex-wrap">
            <input type="text" name="search" value="@Model.SearchTerm" class="form-control adm-input" style="width: 250px;" placeholder="Search token or owner..." />
            <button type="submit" class="btn adm-btn-primary"><i class="bi bi-search me-1"></i>Filter</button>
            @if (!string.IsNullOrEmpty(Model.SearchTerm))
            {
                <a href="/Shares" class="btn adm-btn-ghost">Clear</a>
            }
        </form>
    </div>
    <div class="adm-toolbar-right d-flex align-items-center gap-3">
        <span class="badge adm-badge-lg">@Model.TotalShares total shares</span>
        <button type="button" class="btn adm-btn-primary" data-bs-toggle="modal" data-bs-target="#createShareModal">
            <i class="bi bi-plus-lg me-1"></i>Create ShareLink
        </button>
    </div>
</div>

<!-- Create Share Modal -->
<div class="modal fade" id="createShareModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content adm-toast">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-700">Generate New Share</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Create" method="post">
                <div class="modal-body">
                    <div class="mb-4">
                        <label class="adm-label">1. Select User (Owner)</label>
                        <select name="ownerId" id="shareUserSelect" class="form-select adm-input" required onchange="fetchUserFiles(this.value)">
                            <option value="">-- Select User --</option>
                            @foreach (var u in (List<FileVaultAdmin.Models.Domain.AppUser>)ViewBag.AllUsers)
                            {
                                <option value="@u.Id">@u.FullName (@u.Email)</option>
                            }
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="adm-label">2. Select Asset</label>
                        <select name="fileId" id="shareFileSelect" class="form-select adm-input" required disabled>
                            <option value="">Select user first...</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="adm-label">3. Days of Access</label>
                        <input type="number" name="days" value="7" min="0" class="form-control adm-input" required />
                        <small class="text-muted small">Enter 0 for lifetime access.</small>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn adm-btn-ghost" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn adm-btn-primary px-4">Generate Link</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="adm-card">
    <div class="table-responsive">
        <table class="table adm-table mb-0">
            <thead><tr><th>Token</th><th>Owner</th><th>Download</th><th>Accesses</th><th>Expires</th><th>Status</th><th class="text-end">Actions</th></tr></thead>
            <tbody>
            @foreach (var s in Model.Shares)
            {
                <tr class="animate-fade-in">
                    <td><code class="adm-code">@s.Token[..Math.Min(12, s.Token.Length)]…</code></td>
                    <td class="adm-text-muted">@(s.OwnerEmail ?? s.OwnerUserId[..Math.Min(8, s.OwnerUserId.Length)])</td>
                    <td>
                        @if (s.AllowDownload) { <i class="bi bi-check-circle-fill text-success"></i> }
                        else { <i class="bi bi-x-circle text-danger"></i> }
                    </td>
                    <td><span class="badge adm-badge">@s.AccessCount</span></td>
                    <td class="adm-text-muted">@(s.ExpiresAt?.ToString("MMM dd, yyyy") ?? "Never")</td>
                    <td>
                        @if (s.IsRevoked) { <span class="badge bg-danger bg-opacity-25 text-danger">Revoked</span> }
                        else if (s.ExpiresAt.HasValue && s.ExpiresAt.Value < DateTime.UtcNow) { <span class="badge bg-warning bg-opacity-25 text-warning">Expired</span> }
                        else { <span class="badge bg-success bg-opacity-25 text-success">Active</span> }
                    </td>
                    <td class="text-end">
                        <div class="d-flex gap-1 justify-content-end">
                            <a href="/Shares/Details/@s.Id" class="btn btn-sm adm-btn-icon text-info" title="View Info">
                                <i class="bi bi-eye"></i>
                            </a>
                            <form asp-action="ToggleStatus" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@s.Id" />
                                <button type="submit" class="btn btn-sm adm-btn-icon @(s.IsRevoked ? "text-success" : "text-warning")" title="@(s.IsRevoked ? "Activate" : "Deactivate")">
                                    <i class="bi bi-@(s.IsRevoked ? "play-circle" : "slash-circle")"></i>
                                </button>
                            </form>
                            <form asp-action="Delete" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@s.Id" />
                                <button type="submit" class="btn btn-sm adm-btn-icon text-danger" title="Delete" onclick="return confirm('Delete this share link permanently?')">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    @if (Model.TotalPages > 1)
    {
        <div class="adm-pagination">
            @for (int p = 1; p <= Model.TotalPages; p++)
            {
                <a href="/Shares?page=@p" class="btn btn-sm @(p == Model.Page ? "adm-btn-primary" : "adm-btn-ghost")">@p</a>
            }
        </div>
    }
</div>

@section Scripts {
<script>
async function fetchUserFiles(userId) {
    const fileSelect = document.getElementById('shareFileSelect');
    fileSelect.disabled = true;
    fileSelect.innerHTML = '<option value="">Loading files...</option>';

    if (!userId) {
        fileSelect.innerHTML = '<option value="">Select user first...</option>';
        return;
    }

    try {
        const resp = await fetch(`/Shares/GetFilesByUser?userId=${userId}`);
        const files = await resp.json();
        
        fileSelect.innerHTML = files.length > 0 
            ? '<option value="">-- Select File --</option>' 
            : '<option value="">No files found for this user</option>';
            
        files.forEach(f => {
            const opt = document.createElement('option');
            opt.value = f.id;
            opt.textContent = f.name;
            fileSelect.appendChild(opt);
        });
        
        if (files.length > 0) fileSelect.disabled = false;
    } catch (err) {
        fileSelect.innerHTML = '<option value="">Error loading files</option>';
    }
}
</script>
}
